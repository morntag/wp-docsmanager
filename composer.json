{
  "name": "morntag/wp-docsmanager",
  "description": "Standalone documentation manager module for WordPress plugins. Provides a custom post type, admin UI, Tiptap-based Markdown editor, and filesystem scanner for per-module READMEs.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "morntag.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "erusev/parsedown": "^1.7",
    "erusev/parsedown-extra": "^0.8",
    "symfony/yaml": "^6.0"
  },
  "require-dev": {
    "phpstan/phpstan": "*",
    "phpstan/extension-installer": "*",
    "phpunit/phpunit": "^10.0",
    "squizlabs/php_codesniffer": "^3.10",
    "szepeviktor/phpstan-wordpress": "*",
    "wp-coding-standards/wpcs": "^3.1"
  },
  "autoload": {
    "psr-4": {
      "Morntag\\WpDocsManager\\": ""
    },
    "exclude-from-classmap": [
      "assets/",
      "views/",
      "node_modules/",
      "tests/"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Morntag\\WpDocsManager\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "phpstan/extension-installer": true
    }
  },
  "scripts": {
    "phpstan": "phpstan analyse --memory-limit=1G",
    "phpcs": "./vendor/bin/phpcs -d memory_limit=1G",
    "phpcbf": "./vendor/bin/phpcbf -d memory_limit=1G",
    "test": "./vendor/bin/phpunit"
  }
}
